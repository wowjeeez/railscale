flowchart LR
    subgraph source["StreamSource"]
        direction TB
        tcp["TcpListener::accept()"]
        rh["ReadHalf"]
        wh["WriteHalf"]
        tcp --> rh
        tcp --> wh
    end

    subgraph parsing["FrameParser + Codec"]
        direction TB
        codec["HttpStreamingCodec\n(memchr \\r\\n split)"]
        parsed["ParsedData::Parsed\n(HttpFrame)"]
        pass["ParsedData::Passthrough\n(Body Bytes)"]
        codec --> parsed
        codec --> pass
    end

    subgraph concurrent["Concurrent Fork"]
        direction TB

        subgraph routing["DestinationRouter"]
            rk["routing_key()\n(Host / Request Line)"]
            route["route() -> TcpStream\n(async TCP connect)"]
            rk --> route
        end

        subgraph pipeline["FramePipeline (rayon)"]
            direction TB
            m1["Matcher 1"]
            m2["Matcher 2"]
            m3["Matcher N"]
            rewrite["frame.into_bytes()"]
            m1 --> rewrite
            m2 --> rewrite
            m3 --> rewrite
        end
    end

    subgraph dest["StreamDestination"]
        direction TB
        write["destination.write()\n(processed headers)"]
        passw["destination.write()\n(passthrough body)"]
        relay["relay_response()\ntokio::io::copy\n(upstream -> client)"]
        write --> relay
        passw --> relay
    end

    rh --> codec
    parsed --> rk
    parsed --> m1 & m2 & m3
    pass --> passw
    rewrite --> write
    route --> dest
    relay -.-> wh

    style source fill:#1a1a2e,stroke:#e94560,color:#fff
    style parsing fill:#16213e,stroke:#0f3460,color:#fff
    style concurrent fill:#0f3460,stroke:#533483,color:#fff
    style routing fill:#1a1a2e,stroke:#e94560,color:#fff
    style pipeline fill:#1a1a2e,stroke:#f5a623,color:#fff
    style dest fill:#16213e,stroke:#00b4d8,color:#fff

    style tcp fill:#e94560,stroke:#e94560,color:#fff
    style rh fill:#e94560,stroke:#e94560,color:#fff
    style wh fill:#e94560,stroke:#e94560,color:#fff
    style codec fill:#0f3460,stroke:#0f3460,color:#fff
    style parsed fill:#533483,stroke:#533483,color:#fff
    style pass fill:#f5a623,stroke:#f5a623,color:#000
    style rk fill:#00b4d8,stroke:#00b4d8,color:#fff
    style route fill:#00b4d8,stroke:#00b4d8,color:#fff
    style m1 fill:#f5a623,stroke:#f5a623,color:#000
    style m2 fill:#f5a623,stroke:#f5a623,color:#000
    style m3 fill:#f5a623,stroke:#f5a623,color:#000
    style rewrite fill:#533483,stroke:#533483,color:#fff
    style write fill:#00b4d8,stroke:#00b4d8,color:#fff
    style passw fill:#f5a623,stroke:#f5a623,color:#000
    style relay fill:#e94560,stroke:#e94560,color:#fff
